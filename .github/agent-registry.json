{
  "$schema": "../tools/schemas/agent-registry.schema.json",
  "description": "Agent registry for the Agentic ALZ Accelerator \u2014 enterprise-scale landing zone lifecycle.",
  "scope_types": {
    "estate": "Operates across all landing zones (monitoring, governance, orchestration)",
    "per-lz": "Scoped to a single landing zone instance (platform or application)"
  },
  "delegation_rules": {
    "interactive": "Use handoff \u2014 agent needs user interaction (askQuestions)",
    "autonomous": "Use runSubagent \u2014 agent runs to completion without user input"
  },
  "landing_zone_types": {
    "platform": {
      "description": "CAF enterprise-scale platform subscriptions",
      "members": [
        "platform-management",
        "platform-connectivity",
        "platform-identity",
        "platform-security"
      ],
      "deploy_order": [
        "management",
        "connectivity",
        "identity",
        "security"
      ],
      "workflow": ".github/workflows/2-platform-deploy.yml"
    },
    "application": {
      "description": "Workload landing zones stamped on top of the platform",
      "members": [],
      "workflow": ".github/workflows/3-app-deploy.yml"
    }
  },
