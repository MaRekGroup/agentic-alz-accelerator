{
  "$schema": "../tools/schemas/agent-registry.schema.json",
  "description": "Agent registry for the Agentic ALZ Accelerator — enterprise-scale landing zone lifecycle.",
  "scope_types": {
    "estate": "Operates across all landing zones (monitoring, governance, orchestration)",
    "per-lz": "Scoped to a single landing zone instance (platform or application)"
  },
  "delegation_rules": {
    "interactive": "Use handoff — agent needs user interaction (askQuestions)",
    "autonomous": "Use runSubagent — agent runs to completion without user input"
  },
  "landing_zone_types": {
    "platform": {
      "description": "CAF enterprise-scale platform subscriptions",
      "members": ["platform-management", "platform-connectivity", "platform-identity", "platform-security"],
      "deploy_order": ["management", "connectivity", "identity", "security"],
      "workflow": ".github/workflows/2-platform-deploy.yml"
    },
    "application": {
      "description": "Workload landing zones stamped on top of the platform",
      "members": [],
      "workflow": ".github/workflows/3-app-deploy.yml"
    }
  },
  "agents": {
    "orchestrator": {
      "agent": ".github/agents/orchestrator.md",
      "codename": "Conductor",
      "emoji": "🧠",
      "step": null,
      "scope": "estate",
      "delegation": "interactive",
      "skills": ["workflow-engine", "session-resume", "github-operations"],
      "invokable": true,
      "description": "Master orchestrator — routes workflow steps, enforces approval gates, manages estate state"
    },
    "requirements": {
      "agent": ".github/agents/requirements.md",
      "codename": "Scribe",
      "emoji": "📜",
      "step": 1,
      "scope": "per-lz",
      "delegation": "interactive",
      "skills": ["caf-design-areas", "azure-defaults"],
      "invokable": true,
      "description": "Captures landing zone requirements through conversation"
    },
    "architect": {
      "agent": ".github/agents/architect.md",
      "codename": "Oracle",
      "emoji": "🏛️",
      "step": 2,
      "scope": "per-lz",
      "delegation": "autonomous",
      "skills": ["caf-design-areas", "cost-governance", "azure-defaults", "azure-cost-optimization"],
      "invokable": true,
      "description": "WAF assessment, CAF design area mapping, cost estimation"
    },
    "design": {
      "agent": null,
      "codename": "Artisan",
      "emoji": "🎨",
      "step": 3,
      "scope": "per-lz",
      "delegation": "autonomous",
      "skills": ["drawio", "python-diagrams"],
      "invokable": false,
      "optional": true,
      "description": "Architecture diagrams and ADRs"
    },
    "governance": {
      "agent": ".github/agents/governance.md",
      "codename": "Warden",
      "emoji": "🛡️",
      "step": 3.5,
      "scope": "estate",
      "delegation": "autonomous",
      "skills": ["security-baseline", "caf-design-areas", "azure-compliance", "azure-rbac"],
      "invokable": true,
      "description": "Policy discovery, compliance constraints, security baseline across the estate"
    },
    "iac-planner": {
      "agent": ".github/agents/iac-planner.md",
      "codename": "Strategist",
      "emoji": "📐",
      "step": 4,
      "scope": "per-lz",
      "delegation": "interactive",
      "skills": ["profile-management", "iac-common", "azure-defaults"],
      "invokable": true,
      "description": "Implementation planning with AVM module selection"
    },
    "bicep-code": {
      "agent": ".github/agents/bicep-code.md",
      "codename": "Forge",
      "emoji": "⚒️",
      "step": 5,
      "scope": "per-lz",
      "delegation": "autonomous",
      "subagents": ["bicep-validate-subagent", "bicep-whatif-subagent"],
      "skills": ["azure-bicep-patterns", "security-baseline", "iac-common", "azure-diagnostics"],
      "invokable": true,
      "description": "Bicep template generation (AVM-first)"
    },
    "terraform-code": {
      "agent": null,
      "codename": "Forge",
      "emoji": "⚒️",
      "step": 5,
      "scope": "per-lz",
      "delegation": "autonomous",
      "skills": ["terraform-patterns", "security-baseline", "iac-common", "azure-diagnostics"],
      "invokable": false,
      "description": "Terraform configuration generation (AVM-TF)"
    },
    "deployment": {
      "agent": ".github/agents/deployment.md",
      "codename": "Envoy",
      "emoji": "🚀",
      "step": 6,
      "scope": "per-lz",
      "delegation": "autonomous",
      "skills": ["profile-management", "github-operations"],
      "invokable": true,
      "description": "Deployment with what-if/plan preview via GitHub Actions"
    },
    "documentation": {
      "agent": null,
      "codename": "Chronicler",
      "emoji": "📚",
      "step": 7,
      "scope": "per-lz",
      "delegation": "autonomous",
      "skills": ["azure-diagnostics"],
      "invokable": false,
      "description": "Post-deployment documentation suite (TDD, runbook, inventory)"
    },
    "monitoring": {
      "agent": ".github/agents/monitoring.md",
      "codename": "Sentinel",
      "emoji": "🔭",
      "step": 8,
      "scope": "estate",
      "delegation": "autonomous",
      "continuous": true,
      "skills": ["security-baseline", "cost-governance", "azure-diagnostics", "azure-compliance"],
      "invokable": true,
      "description": "Continuous compliance monitoring, drift detection across ALL landing zones"
    },
    "remediation": {
      "agent": ".github/agents/remediation.md",
      "codename": "Mender",
      "emoji": "🔧",
      "step": 9,
      "scope": "estate",
      "delegation": "autonomous",
      "triggered_by": "monitoring",
      "skills": ["security-baseline", "azure-diagnostics", "azure-rbac"],
      "invokable": true,
      "description": "Auto-remediation with snapshot/rollback across ALL landing zones"
    },
    "challenger": {
      "agent": ".github/agents/challenger.md",
      "codename": "Challenger",
      "emoji": "⚔️",
      "step": null,
      "scope": "per-lz",
      "delegation": "autonomous",
      "gates": ["gate-1", "gate-2", "gate-4", "gate-5"],
      "skills": ["security-baseline", "cost-governance", "caf-design-areas", "azure-compliance"],
      "invokable": true,
      "description": "Adversarial reviewer — challenges architecture, plans, code, and security"
    },
    "assessment": {
      "agent": ".github/agents/assessment.md",
      "codename": "Assessor",
      "emoji": "🔍",
      "step": null,
      "scope": "estate",
      "delegation": "autonomous",
      "skills": ["brownfield-discovery", "wara-assessment", "assessment-report"],
      "invokable": true,
      "description": "Brownfield discovery, WARA/CAF assessment, and environment documentation generation"
    }
  },
  "updated": "2026-04-29"
}
