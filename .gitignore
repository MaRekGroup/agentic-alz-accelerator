# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Environment
.env

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# alz-recall index
tmp/

# pytest
.pytest_cache/
htmlcov/
.coverage

# Copilot hook logs
logs/copilot/

# Node / Astro docs site
node_modules/
site/dist/
site/.astro/

# Customer output (per-customer folders under agent-output/)
# Keep agent-output/README.md and sample skeleton tracked
agent-output/*/
!agent-output/README.md

# Customer-specific config (real values — use .sample files as templates)
environments/subscriptions.json

# Customer IaC (per-customer folders under infra/{bicep,terraform}/)
# Keep README.md tracked as template documentation
infra/bicep/*/
!infra/bicep/README.md
infra/terraform/*/
!infra/terraform/README.md
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
