# Azure AI Agent Service
AZURE_AI_PROJECT_CONNECTION_STRING=your-connection-string
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure Authentication (uses DefaultAzureCredential by default)
# Uncomment to use Service Principal instead of interactive login
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Azure Subscription (target for landing zone deployment)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_MANAGEMENT_GROUP_PREFIX=mrg

# IaC Configuration
IAC_FRAMEWORK=bicep  # or "terraform"
TERRAFORM_STATE_STORAGE_ACCOUNT=your-storage-account
TERRAFORM_STATE_CONTAINER=tfstate

# Monitoring Configuration
MONITOR_INTERVAL_MINUTES=30
DRIFT_CHECK_INTERVAL_MINUTES=60
AUTO_REMEDIATE=false

# Notification
NOTIFICATION_WEBHOOK_URL=https://your-teams-webhook-url
NOTIFICATION_EMAIL=platform-team@your-org.com
