{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "azure-pricing": {
      "type": "stdio",
      "command": "python",
      "args": [
        "-m",
        "azure_pricing_mcp"
      ],
      "cwd": "${workspaceFolder}/mcp/azure-pricing-mcp",
      "env": {
        "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}",
        "PYTHONPATH": "${workspaceFolder}/mcp/azure-pricing-mcp/src"
      }
    },
    "terraform": {
      "type": "stdio",
      "command": "terraform-mcp-server",
      "args": [
        "stdio",
        "--toolsets",
        "registry"
      ],
      "env": {}
    },
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp?maxTokenBudget=4000"
    },
    "drawio": {
      "type": "stdio",
      "command": "deno",
      "args": [
        "run",
        "--allow-net",
        "--allow-read",
        "--allow-write",
        "--allow-env",
        "${workspaceFolder}/mcp/drawio-mcp-server/src/index.ts"
      ]
    }
  }
}
