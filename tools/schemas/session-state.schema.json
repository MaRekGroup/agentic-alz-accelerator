{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MaRekGroup/agentic-alz-accelerator/schemas/session-state.schema.json",
  "title": "Session State",
  "description": "Per-landing-zone session state tracking the 10-step ALZ workflow (steps 0–9).",
  "type": "object",
  "required": ["schema_version", "project", "landing_zone", "iac_tool", "region", "updated", "current_step", "steps"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "2.0"],
      "description": "Schema version for forward compatibility."
    },
    "project": {
      "type": "string",
      "minLength": 1,
      "description": "Project or customer name."
    },
    "landing_zone": {
      "type": "string",
      "minLength": 1,
      "description": "Landing zone identifier (e.g. platform-management, app-web)."
    },
    "iac_tool": {
      "type": "string",
      "enum": ["", "bicep", "terraform"],
      "description": "IaC framework selected for this landing zone."
    },
    "region": {
      "type": "string",
      "description": "Primary Azure region for this landing zone."
    },
    "branch": {
      "type": "string",
      "description": "Git branch associated with this session."
    },
    "updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of the last session update."
    },
    "current_step": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9,
      "description": "Current workflow step (0 = brownfield assessment, 1–7 = core workflow, 8–9 = day-2)."
    },
    "decisions": {
      "type": "object",
      "description": "Key decisions captured during the workflow.",
      "required": ["region", "compliance", "budget", "architecture_pattern", "deployment_strategy"],
      "additionalProperties": true,
      "properties": {
        "region": {
          "type": "string",
          "description": "Chosen deployment region."
        },
        "compliance": {
          "type": "string",
          "description": "Compliance framework or level (e.g. CIS, NIST, none)."
        },
        "budget": {
          "type": "string",
          "description": "Budget allocation or tier."
        },
        "architecture_pattern": {
          "type": "string",
          "description": "Selected architecture pattern (e.g. hub-spoke, vwan)."
        },
        "deployment_strategy": {
          "type": "string",
          "description": "Deployment strategy (e.g. incremental, complete)."
        },
        "complexity": {
          "type": "string",
          "enum": ["simple", "standard", "complex", ""],
          "description": "Complexity classification for challenger gate depth."
        }
      }
    },
    "open_findings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Outstanding findings or blockers."
    },
    "steps": {
      "type": "object",
      "description": "Status of each workflow step, keyed by step identifier.",
      "patternProperties": {
        "^[0-9_]+$": { "$ref": "#/$defs/stepEntry" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "stepEntry": {
      "type": "object",
      "description": "Status record for a single workflow step.",
      "required": ["name", "agent", "status"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable step name."
        },
        "agent": {
          "type": "string",
          "description": "Agent codename responsible for this step."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "complete", "skipped"],
          "description": "Current status of the step."
        },
        "started": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp when the step started, or null."
        },
        "completed": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp when the step completed, or null."
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Paths to artifacts produced by this step."
        }
      }
    }
  }
}
