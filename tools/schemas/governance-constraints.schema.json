{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MaRekGroup/agentic-alz-accelerator/schemas/governance-constraints.schema.json",
  "title": "Governance Constraints",
  "description": "Discovered governance constraints from Azure Policy and compliance scans.",
  "type": "object",
  "required": ["schema_version", "subscription_id", "discovered_at", "findings"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "governance-constraints-v1",
      "description": "Fixed schema version identifier."
    },
    "subscription_id": {
      "type": "string",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}|unknown)$",
      "description": "Azure subscription ID (UUID) or 'unknown'."
    },
    "discovered_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when the constraints were discovered."
    },
    "findings": {
      "type": "array",
      "description": "Policy findings from the governance scan.",
      "items": { "$ref": "#/$defs/finding" }
    },
    "tags_required": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tag keys that are required by policy."
    },
    "allowed_locations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Azure regions allowed by policy."
    },
    "policies": {
      "type": "array",
      "description": "Additional raw policy entries.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "source": {
      "type": "string",
      "description": "Source of the governance constraints (e.g. azure-policy, manual)."
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "description": "A single policy finding.",
      "required": ["policy_id", "display_name", "effect"],
      "additionalProperties": true,
      "properties": {
        "policy_id": {
          "type": "string",
          "description": "Azure Policy definition ID or name."
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable policy display name."
        },
        "effect": {
          "type": "string",
          "enum": ["deny", "audit", "auditIfNotExists", "append", "modify", "deployIfNotExists", "disabled"],
          "description": "Policy effect."
        },
        "scope": {
          "type": "string",
          "description": "Scope at which the policy is assigned."
        },
        "azurePropertyPath": {
          "type": "string",
          "description": "ARM property path affected by this policy."
        },
        "bicepPropertyPath": {
          "type": "string",
          "description": "Bicep property path to set for compliance."
        },
        "terraformPropertyPath": {
          "type": "string",
          "description": "Terraform argument path to set for compliance."
        },
        "required_value": {
          "description": "Value required by the policy (type varies)."
        },
        "resource_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Azure resource types this policy applies to."
        }
      }
    }
  }
}
