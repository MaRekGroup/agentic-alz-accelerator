        FW["🔥 Azure Firewall Premium<br/>Threat Intel: Deny | TLS Inspect | IDPS"]:::hub
        ERGW["⚡ ExpressRoute Gateway<br/>ErGw1AZ"]:::hub
        VPNGW["🔒 VPN Gateway<br/>VpnGw2AZ Active-Active"]:::hub
        BASTION_HUB["🖥️ Azure Bastion<br/>Standard · 2 Scale Units"]:::hub
        DDOS["🛡️ DDoS Protection Plan"]:::hub

        subgraph DNS_RESOLVER["Private DNS Resolver"]
