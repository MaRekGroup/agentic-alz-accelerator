    subgraph SEC_SPOKE["Security — Dedicated"]
        SENTINEL_S["🔭 Sentinel Dedicated<br/>730-day retention"]:::service
        DEFENDER["🛡️ Defender for Cloud<br/>12 Plans Enabled"]:::service
        SOAR["🤖 SOAR Playbooks x4"]:::service
        KV_SEC["🔑 Security Key Vault"]:::service
