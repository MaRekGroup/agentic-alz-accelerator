%%{ init: { 'theme': 'base', 'themeVariables': { 'fontSize': '12px' } } }%%
graph TB
    classDef hub fill:#2d6a9f,stroke:#1a4e7a,color:#fff,font-weight:bold
    classDef spoke fill:#4a9e4a,stroke:#2d6b27,color:#fff
    classDef service fill:#e8f0fe,stroke:#4285f4,color:#1a1a1a,font-size:11px
    classDef onprem fill:#8b5e3c,stroke:#5a3d28,color:#fff
    classDef internet fill:#c62828,stroke:#8e1c1c,color:#fff
    classDef dns fill:#7b1fa2,stroke:#4a148c,color:#fff

    INTERNET["☁️ Internet"]:::internet
    ONPREM["🏠 On-Premises<br/>Corporate Network"]:::onprem

    subgraph HUB["Connectivity Hub — 10.0.0.0/16"]
