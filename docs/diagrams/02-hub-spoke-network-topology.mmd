            DNS_OUT["DNS Outbound<br/>10.0.3.16/28"]:::dns
        end

        PDNS["📋 20 Private DNS Zones<br/>blob · sql · vault · acr · openai · etc."]:::dns
    end

    subgraph MGMT_SPOKE["Management — 10.100.0.0/24"]
        LAW["📊 Log Analytics<br/>365-day retention"]:::service
        AUTO["⚙️ Automation Account"]:::service
        ALERTS["🔔 Action Group"]:::service
        SENTINEL_M["🔭 Sentinel"]:::service
    end

    subgraph ID_SPOKE["Identity — 10.101.0.0/24"]
