{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "13049784733883252294"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region"
      }
    },
    "prefix": {
      "type": "string",
      "metadata": {
        "description": "Resource name prefix"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Tags"
      }
    },
    "budgetAmount": {
      "type": "int",
      "metadata": {
        "description": "Monthly budget amount in USD"
      }
    },
    "technicalContact": {
      "type": "string",
      "metadata": {
        "description": "Technical contact email for budget alerts"
      }
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Environment name"
      }
    },
    "now": {
      "type": "string",
      "defaultValue": "[utcNow('yyyy-MM-01')]"
    }
  },
  "variables": {
    "regionShortcode": "[coalesce(createObject('eastus', 'eus', 'eastus2', 'eus2', 'westus', 'wus', 'westus2', 'wus2', 'westus3', 'wus3', 'centralus', 'cus', 'southcentralus', 'scus', 'northeurope', 'neu', 'westeurope', 'weu', 'uksouth', 'uks', 'southeastasia', 'sea', 'australiaeast', 'aue', 'japaneast', 'jpe')[parameters('location')], parameters('location'))]",
    "rgName": "[format('{0}-identity-{1}-rg', parameters('prefix'), variables('regionShortcode'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[variables('rgName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, format('{0}-agent-identity', parameters('prefix')), 'Reader')]",
      "properties": {
        "principalId": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.agentIdentityPrincipalId.value]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'acdd72a7-3385-48ef-bd42-f606fba81ae7')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment')]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, format('{0}-agent-identity', parameters('prefix')), 'ResourcePolicyContributor')]",
      "properties": {
        "principalId": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.agentIdentityPrincipalId.value]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '36243c78-bf99-498c-9df9-86d9f8d28608')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment')]"
      ]
    },
    {
      "type": "Microsoft.Consumption/budgets",
      "apiVersion": "2023-11-01",
      "name": "[format('budget-identity-{0}', parameters('environment'))]",
      "properties": {
        "timePeriod": {
          "startDate": "[parameters('now')]"
        },
        "timeGrain": "Monthly",
        "amount": "[parameters('budgetAmount')]",
        "category": "Cost",
        "notifications": {
          "forecast80": {
            "enabled": true,
            "operator": "GreaterThanOrEqualTo",
            "threshold": 80,
            "thresholdType": "Forecasted",
            "contactEmails": [
              "[parameters('technicalContact')]"
            ]
          },
          "forecast100": {
            "enabled": true,
            "operator": "GreaterThanOrEqualTo",
            "threshold": 100,
            "thresholdType": "Forecasted",
            "contactEmails": [
              "[parameters('technicalContact')]"
            ]
          },
          "forecast120": {
            "enabled": true,
            "operator": "GreaterThanOrEqualTo",
            "threshold": 120,
            "thresholdType": "Forecasted",
            "contactEmails": [
              "[parameters('technicalContact')]"
            ]
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "identity-resources-deployment",
      "resourceGroup": "[variables('rgName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "prefix": {
            "value": "[parameters('prefix')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "4357793860761366685"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "prefix": {
              "type": "string",
              "metadata": {
                "description": "Resource name prefix"
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "Tags"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}-identity', parameters('prefix'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]"
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[format('{0}-agent-identity', parameters('prefix'))]",
              "location": "[parameters('location')]",
              "tags": "[union(parameters('tags'), createObject('purpose', 'alz-agent-operations'))]"
            }
          ],
          "outputs": {
            "managedIdentityId": {
              "type": "string",
              "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('prefix')))]"
            },
            "managedIdentityPrincipalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('prefix'))), '2023-01-31').principalId]"
            },
            "managedIdentityClientId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-identity', parameters('prefix'))), '2023-01-31').clientId]"
            },
            "agentIdentityId": {
              "type": "string",
              "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-agent-identity', parameters('prefix')))]"
            },
            "agentIdentityPrincipalId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-agent-identity', parameters('prefix'))), '2023-01-31').principalId]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', variables('rgName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[variables('rgName')]"
    },
    "managedIdentityId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.managedIdentityId.value]"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.managedIdentityPrincipalId.value]"
    },
    "managedIdentityClientId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.managedIdentityClientId.value]"
    },
    "agentIdentityId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.agentIdentityId.value]"
    },
    "agentIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'identity-resources-deployment'), '2025-04-01').outputs.agentIdentityPrincipalId.value]"
    }
  }
}